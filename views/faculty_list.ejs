<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title><%= siteTitle %></title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('partials/header')%>
    <h2><%= title %></h2>
    <ul>
        <%items.forEach(item => { %>
            <li>
                <span class = "name"><%= item.name %></span>
                <ul class = "details">
                    <li> ID: <%= item.id %></li>
                    <li> Email: <%= item.email %></li>
                    <li> Hire Date: <%= item.hire_date %></li>
                </ul>
            </li>
        <% }); %>
    </ul>
    <%- include('partials/footer') %>
</body>
</html>